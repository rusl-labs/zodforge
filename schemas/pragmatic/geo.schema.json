{"$comment":"Implements GeoJSON geometry per RFC 7946. WGS84, lon-first. Reference a geometry by fragment, e.g. https://resources.rusl.com/resources/pragmatic/geo#/$defs/point.","$defs":{"bbox":{"description":"Bounding box per RFC 7946 §5. [minLon, minLat, maxLon, maxLat] or with elevation.","items":{"type":"number"},"maxItems":6,"minItems":4,"type":"array"},"geometry":{"anyOf":[{"$ref":"#/$defs/point"},{"$ref":"#/$defs/multiPoint"},{"$ref":"#/$defs/lineString"},{"$ref":"#/$defs/multiLineString"},{"$ref":"#/$defs/polygon"},{"$ref":"#/$defs/multiPolygon"},{"$ref":"#/$defs/geometryCollection"}],"description":"Any GeoJSON geometry object."},"geometryCollection":{"additionalProperties":false,"properties":{"bbox":{"$ref":"#/$defs/bbox"},"geometries":{"items":{"$ref":"#/$defs/geometry"},"type":"array"},"type":{"const":"GeometryCollection"}},"required":["type","geometries"],"type":"object"},"lineString":{"additionalProperties":false,"properties":{"bbox":{"$ref":"#/$defs/bbox"},"coordinates":{"items":{"$ref":"#/$defs/position"},"minItems":2,"type":"array"},"type":{"const":"LineString"}},"required":["type","coordinates"],"type":"object"},"linearRing":{"description":"A closed ring: at least 4 positions with the first equal to the last. Closure, winding order, and non-self-intersection are not schema-enforceable.","items":{"$ref":"#/$defs/position"},"minItems":4,"type":"array"},"multiLineString":{"additionalProperties":false,"properties":{"bbox":{"$ref":"#/$defs/bbox"},"coordinates":{"items":{"items":{"$ref":"#/$defs/position"},"minItems":2,"type":"array"},"type":"array"},"type":{"const":"MultiLineString"}},"required":["type","coordinates"],"type":"object"},"multiPoint":{"additionalProperties":false,"properties":{"bbox":{"$ref":"#/$defs/bbox"},"coordinates":{"items":{"$ref":"#/$defs/position"},"type":"array"},"type":{"const":"MultiPoint"}},"required":["type","coordinates"],"type":"object"},"multiPolygon":{"additionalProperties":false,"properties":{"bbox":{"$ref":"#/$defs/bbox"},"coordinates":{"items":{"items":{"$ref":"#/$defs/linearRing"},"type":"array"},"minItems":1,"type":"array"},"type":{"const":"MultiPolygon"}},"required":["type","coordinates"],"type":"object"},"point":{"additionalProperties":false,"properties":{"bbox":{"$ref":"#/$defs/bbox"},"coordinates":{"$ref":"#/$defs/position"},"type":{"const":"Point"}},"required":["type","coordinates"],"type":"object"},"polygon":{"additionalProperties":false,"properties":{"bbox":{"$ref":"#/$defs/bbox"},"coordinates":{"items":{"$ref":"#/$defs/linearRing"},"minItems":1,"type":"array"},"type":{"const":"Polygon"}},"required":["type","coordinates"],"type":"object"},"position":{"description":"[lon, lat] or [lon, lat, elevation] -- LON FIRST (WGS84). The optional 3rd element is altitude/elevation per RFC 7946 section 3.1.1; never a 4th. Elevation units are unspecified (convention: meters).","items":{"type":"number"},"maxItems":3,"minItems":2,"prefixItems":[{"maximum":180,"minimum":-180,"type":"number"},{"maximum":90,"minimum":-90,"type":"number"}],"type":"array"}},"$id":"https://resources.rusl.com/resources/pragmatic/schemas/geo","$ref":"#/$defs/geometry","$schema":"https://json-schema.org/draft/2020-12/schema","title":"Geometry (GeoJSON, RFC 7946)","version":"0.1.0"}